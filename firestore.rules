rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - role: string (required, ['admin', 'professor'])
    //   - status: string (required, ['active', 'blocked'])
    //
    // Collection: logs
    // Document ID: {logId}
    // Fields:
    //   - professorId: string (required)
    //   - professorName: string (required)
    //   - roomNumber: string (required)
    //   - timestamp: string (required, ISO 8601)
    //   - type: string (required, ['login', 'logout'])
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email in ["anthonvan.calban@neu.edu.ph", "jcesperanza@neu.edu.ph"]);
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'professor'] &&
             data.status in ['active', 'blocked'];
    }

    function isValidLog(data) {
      return data.professorId is string &&
             data.professorName is string &&
             data.roomNumber is string &&
             data.timestamp is string &&
             data.type in ['login', 'logout'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'professor';
      allow update: if isAdmin() && isValidUser(request.resource.data);
    }

    match /logs/{logId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.professorId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.professorId == request.auth.uid && isValidLog(request.resource.data);
      allow update, delete: if isAdmin();
    }
  }
}
